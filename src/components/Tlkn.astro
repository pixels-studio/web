---
import { Image } from "astro:assets";
import tlkn from "../assets/media/tlkn.png";
---

<section
  class="relative z-10 flex md:min-h-dvh flex-col justify-center px-6 py-20 md:py-40"
>
  <div class="mx-auto w-full max-w-[1464px]">
    <div class="grid grid-cols-6 gap-6 md:grid-cols-12 md:items-center">
      <div class="col-span-6 md:col-span-4 flex flex-col gap-6">
        <p class="font-mono text-xs uppercase text-ink-secondary" data-reveal>Tlkn</p>
        <h2
          data-split-text
          class="text-4xl md:text-6xl font-semibold leading-none tracking-tight text-pretty"
        >
          Privacy-first HD voice calling
        </h2>
        <p data-reveal class="text-lg md:text-xl leading-relaxed text-ink-secondary text-pretty">
          Designed iOS and Android apps from scratch for a privacy-focused
          HD calling platform. Reached 50,000 users.
        </p>
      </div>

      <div class="col-span-6 md:col-span-6 md:col-start-7">
        <Image
          src={tlkn}
          alt="Tlkn preview"
          class="w-full md:max-w-8/10 mx-auto"
        />
      </div>
    </div>
  </div>
</section>
