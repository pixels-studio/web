---
import { Image } from "astro:assets";
import prism from "../assets/media/prism.png";
---

<section class="relative z-10 flex md:min-h-dvh flex-col px-6 py-20 md:py-40">
  <div class="mx-auto w-full max-w-[1464px] flex flex-1 flex-col gap-15">
    <div class="grid grid-cols-6 gap-6 md:grid-cols-12 md:items-end">
      <div class="col-span-6 md:col-span-5 flex flex-col gap-6">
        <p class="font-mono text-xs uppercase text-ink-secondary" data-reveal>Prism</p>
        <h2
          data-split-text
          class="text-4xl md:text-6xl font-semibold leading-none tracking-tight text-pretty"
        >
          Graphic styles at the speed of thought
        </h2>
      </div>

      <p
        data-reveal
        class="col-span-6 md:col-span-4 md:col-start-9 md:self-end text-lg md:text-xl leading-relaxed text-ink-secondary text-pretty"
      >
        A browser-based graphic style studio for applying artistic effects to
        images in real time. Duotone, halftone, ASCII art, glitch, and more —
        powered by WebGL.
      </p>
    </div>

    <div class="mt-auto grid grid-cols-6 gap-6 md:grid-cols-12">
      <div class="col-span-6 md:col-span-12 overflow-hidden">
        <Image
          src={prism}
          alt="Prism graphic style studio preview"
          data-scale-in
          class="w-full object-cover"
        />
      </div>
    </div>
  </div>
</section>
