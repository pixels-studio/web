---
import { Image } from "astro:assets";
import rhythm from "../assets/media/rhythm.png";
---

<section class="relative z-10 flex md:min-h-dvh flex-col px-6 py-20 md:py-40">
  <div class="mx-auto w-full max-w-[1360px] flex flex-1 flex-col gap-15">
    <div class="grid grid-cols-6 gap-6 md:grid-cols-12 md:items-end">
      <div class="col-span-6 md:col-span-5 flex flex-col gap-6">
        <p class="font-mono text-xs uppercase text-ink-secondary" data-reveal>Rhythm</p>
        <h2
          data-split-text
          class="text-4xl md:text-6xl font-semibold leading-none tracking-tight text-pretty"
        >
          Abstract patterns for design and web
        </h2>
      </div>

      <p
        data-reveal
        class="col-span-6 md:col-span-5 md:col-start-8 md:self-end text-lg md:text-xl leading-relaxed text-ink-secondary text-pretty"
      >
        Designed and built a real-time generator for abstract patterns using
        lines, dots, ASCII, and Chladni figures. Used by designers for
        backgrounds, textures, and generative artwork.
      </p>
    </div>

    <div class="mt-auto grid grid-cols-6 gap-6 md:grid-cols-12">
      <div class="col-span-6 md:col-span-12 overflow-hidden">
        <Image
          src={rhythm}
          alt="Rhythm generative pattern toolkit preview"
          data-scale-in
          class="w-full object-cover"
        />
      </div>
    </div>
  </div>
</section>
