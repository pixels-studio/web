---

<canvas id="hex-pattern" class="size-full" aria-hidden="true"></canvas>

<script>
  const canvas = document.getElementById("hex-pattern") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;

  const HEX_VALUES = [
    "00", "0D", "3B", "61", "67", "7A", "88",
    "A3", "B2", "C4", "FD", "FE", "FF",
  ];

  // Seeded PRNG for consistent renders across reloads
  function mulberry32(seed: number) {
    return () => {
      seed |= 0; seed = (seed + 0x6d2b79f5) | 0;
      let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
      t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
  }

  const rand = mulberry32(42);

  function resize() {
    const dpr = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.scale(dpr, dpr);
    draw(rect.width, rect.height);
  }

  const CHAR_W = 28;
  const CHAR_H = 18;

  function draw(w: number, h: number) {
    ctx.clearRect(0, 0, w, h);
    ctx.font = "13px 'Fragment Mono', monospace";
    ctx.textBaseline = "middle";
    ctx.textAlign = "left";

    const cols = Math.floor(w / CHAR_W);
    const rows = Math.floor(h / CHAR_H);
    const occupied = new Set<string>();
    const count = Math.floor((cols * rows) * 0.35);

    for (let i = 0; i < count; i++) {
      const col = Math.floor(rand() * cols);
      const row = Math.floor(rand() * rows);
      const key = `${col},${row}`;

      if (occupied.has(key)) continue;
      occupied.add(key);

      const x = col * CHAR_W + (rand() * 6 - 3);
      const y = row * CHAR_H + (rand() * 4 - 2);
      const hex = HEX_VALUES[Math.floor(rand() * HEX_VALUES.length)];
      const opacity = rand() * 0.9 + 0.04;

      ctx.fillStyle = `rgba(255, 255, 255, ${opacity})`;
      ctx.fillText(hex, x, y);
    }
  }

  resize();
  window.addEventListener("resize", resize);
</script>
