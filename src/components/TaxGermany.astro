---
import { Image } from "astro:assets";
import taxGermany from "../assets/media/tax-germany.png";
---

<section class="relative z-10 flex md:min-h-dvh flex-col px-6 py-20 md:py-40">
  <div class="mx-auto w-full max-w-[1360px] flex flex-1 flex-col gap-8 md:gap-15">
    <div class="grid grid-cols-6 gap-6 md:grid-cols-12 md:items-start">
      <p class="col-span-6 md:col-span-12 font-mono text-xs uppercase text-ink-secondary" data-reveal>Tax Germany</p>

      <h2
        data-split-text
        class="col-span-6 md:col-span-5 text-4xl md:text-6xl font-semibold leading-none tracking-tight text-pretty"
      >
        Tax filing, simplified for Germany
      </h2>

      <div class="col-span-6 md:col-span-5 md:col-start-8 grid grid-cols-subgrid gap-6">
        <p
          data-reveal
          class="col-span-full text-lg md:text-xl leading-relaxed text-ink-secondary text-pretty"
        >
          Designed the Freelancer and UG App interfaces and built the design
          systems. A digital tax platform that connects freelancers and holding
          companies with certified advisors for compliant filings in Germany.
        </p>
        <a
          href="https://taxgermany.de"
          target="_blank"
          rel="noopener noreferrer"
          data-reveal
          class="col-span-full md:col-span-2 bg-surface-secondary px-5 py-2.5 font-mono text-sm text-ink-secondary uppercase tracking-wide text-center transition-colors hover:bg-white hover:text-black"
        >
          Learn More
        </a>
      </div>
    </div>

    <Image
      src={taxGermany}
      alt="Tax Germany application preview"
      class="w-full col-span-full border border-ink-primary/8 rounded-lg"
    />
  </div>
</section>
