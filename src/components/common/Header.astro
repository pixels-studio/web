---
import { ROUTES } from '@helpers/routes';
import { cn } from '@helpers/utils';
---

<header
	class={cn('sticky top-0 z-40 bg-base-0 p-4 text-base-10')}
	style="view-transition-name: header"
	data-header
	data-intro
>
	<div
		class={cn(
			'mx-auto grid w-full max-w-[1512px] grid-cols-6 gap-4',
			'md:grid-cols-8',
			'lg:grid-cols-12'
		)}
	>
		<a class={cn('col-span-3 font-medium', 'md:col-span-4', 'lg:col-span-4')} href={ROUTES.home}>
			Abhishek Kambli
		</a>

		<p
			class={cn(
				'col-span-full hidden font-medium text-orange-600',
				'lg:col-span-5 lg:block'
			)}
		>
			Open to new opportunities
		</p>

		<nav class={cn('col-span-3 flex items-center justify-end gap-8', 'md:col-span-4', 'lg:col-span-3')}>
			<a
				href={ROUTES.instagram}
				target="_blank"
				rel="noopener noreferrer"
				class="font-medium text-base-5 transition-colors duration-300 ease-smooth hover:text-base-10"
			>
				Ig
			</a>
			<a
				href={ROUTES.twitter}
				target="_blank"
				rel="noopener noreferrer"
				class="font-medium text-base-5 transition-colors duration-300 ease-smooth hover:text-base-10"
			>
				Tw
			</a>
			<button
				data-email-copy
				data-email={ROUTES.email.replace('mailto:', '')}
				class="cursor-pointer font-medium text-base-5 transition-colors duration-300 ease-smooth hover:text-base-10"
			>
				<span class="grid overflow-hidden" data-email-label>
					<span class="col-start-1 row-start-1">Email</span>
					<span class="col-start-1 row-start-1 invisible" aria-hidden="true">Copied</span>
				</span>
			</button>
		</nav>
	</div>
</header>

<script>
	import { introState } from '@helpers/intro-state';

	document.addEventListener('astro:page-load', () => {
		const header = document.querySelector('[data-header]');
		if (!header) return;
		if (introState.hasPlayed) {
			header.removeAttribute('data-intro');
		} else {
			header.classList.add('header-animate');
		}

		const btn = document.querySelector('[data-email-copy]') as HTMLButtonElement | null;
		if (!btn) return;

		const email = btn.dataset.email || '';
		const label = btn.querySelector('[data-email-label]') as HTMLElement | null;
		const visibleSpan = label?.firstElementChild as HTMLElement | null;

		btn.addEventListener('click', async () => {
			try {
				await navigator.clipboard.writeText(email);
				if (visibleSpan) visibleSpan.textContent = 'Copied';
				setTimeout(() => {
					if (visibleSpan) visibleSpan.textContent = 'Email';
				}, 2000);
			} catch {
				window.location.href = `mailto:${email}`;
			}
		});
	});
</script>

<style>
	@keyframes fadeIn {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	.header-animate {
		animation: fadeIn 0.6s var(--ease-smooth) forwards;
	}
</style>
