---
import { Image } from "astro:assets";
import origonDashboard from "../assets/media/origon-dashboard.png";
---

<section id="work" class="relative z-10 flex md:min-h-dvh flex-col px-6 py-20 md:py-40">
  <div class="mx-auto w-full max-w-[1360px] flex flex-1 flex-col gap-8 md:gap-15">
    <div class="grid grid-cols-6 gap-6 md:grid-cols-12 md:items-end">
      <div class="col-span-6 md:col-span-5 flex flex-col gap-6">
        <p class="font-mono text-xs uppercase text-ink-secondary" data-reveal>Origon</p>
        <h2
          data-split-text
          class="text-4xl md:text-6xl font-semibold leading-none tracking-tight text-pretty"
        >
          An enterprise platform for AI agents
        </h2>
      </div>

      <p
        data-reveal
        class="col-span-6 md:col-span-5 md:col-start-8 md:self-end text-lg md:text-xl leading-relaxed text-ink-secondary text-pretty"
      >
        Designed the platform and built key frontend features for an
        enterprise tool to create and operate multi-agent AI systems at scale.
      </p>
    </div>

    <div class="mt-auto grid grid-cols-6 gap-6 md:grid-cols-12">
      <div class="col-span-6 md:col-span-12 overflow-hidden">
        <Image
          src={origonDashboard}
          alt="Origon dashboard preview"
          data-scale-in
          class="w-full object-cover"
        />
      </div>
    </div>
  </div>
</section>
