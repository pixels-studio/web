---
const id = "footer-logo-pattern";
---

<div data-fade class="relative z-10 w-full overflow-hidden px-6 pt-12 pb-6">
  <svg
    class="w-full"
    viewBox="0 0 1200 160"
    preserveAspectRatio="xMidYMid meet"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <pattern id={id} patternUnits="userSpaceOnUse" width="10" height="12">
        <text
          x="5"
          y="9"
          text-anchor="middle"
          fill="currentColor"
          opacity="0.12"
          font-size="12"
          style="font-family: monospace;"
        >░</text>
      </pattern>
    </defs>
    <text
      x="50%"
      y="50%"
      dominant-baseline="central"
      text-anchor="middle"
      textLength="1160"
      lengthAdjust="spacing"
      fill={`url(#${id})`}
      class="font-sans text-[160px] font-bold uppercase tracking-tight"
      style="font-family: var(--font-inter), sans-serif; font-weight: 800; letter-spacing: -0.02em;"
    >
      PIXELS STUDIO
    </text>
  </svg>
</div>
